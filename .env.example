# PostgreSQL Database Configuration
DB_URL=jdbc:postgresql://postgres:5432/regulatory_change_management
DB_USERNAME=postgres
DB_PASSWORD=secretpassword
JPA_SHOW_SQL=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s
REDIS_CACHE_TTL=15m

# JWT Security
JWT_SECRET=this-is-a-very-secure-secret-key-that-needs-to-be-at-least-256-bits-long
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# Mail Server Configuration (Dummy values for testing)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=test@example.com
MAIL_PASSWORD=testpassword
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# Application URLs
FRONTEND_BASE_URL=http://localhost
SPRING_APP_NAME=regulatory-change-management-backend
BACKEND_PORT=8080
